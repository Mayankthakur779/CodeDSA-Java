import java.util.*;

class Solution {

    public List<String> buildArray(int[] target, int n) {

        List<String> result = new ArrayList<>();
        int index = 0;

        for(int i = 1; i <= n; i++) {

            if(index == target.length)
                break;

            result.add("Push");

            if(i == target[index]) {
                index++;
            } else {
                result.add("Pop");
            }
        }

        return result;
    }
}
