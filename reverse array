import java.util.Arrays;

class Solution {

    public void reverse(int[] arr) {

        int left=0;
        int right=arr.length-1;

        while(left < right){

        
        int temp=arr[left];
        arr[left]=arr[right];
        arr[right]=temp;

        left++;
        right--;

        }

    }
}

public class Reverse1 {

    public static void main(String[] args) {

        int arr[] = {1, 2, 3, 4, 5};

        Solution obj = new Solution();

        obj.reverse(arr);

        System.out.println(Arrays.toString(arr));
    }
}
